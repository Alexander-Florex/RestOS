# ─────────────────────────────────────────────
# Base de datos MySQL
# ─────────────────────────────────────────────
# Formato: mysql://USUARIO:PASSWORD@HOST:PUERTO/BASE
# Si usás XAMPP localmente, el user es root sin password y el puerto 3306
DATABASE_URL="mysql://root:@localhost:3306/restos_db"

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
# Generá uno largo y aleatorio (ej: openssl rand -base64 48)
JWT_SECRET="cambiame-por-un-secreto-largo-y-aleatorio-de-al-menos-32-caracteres"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
# Coma-separado si necesitás varios orígenes (ej: prod + staging)
CORS_ORIGIN="http://localhost:5173"
