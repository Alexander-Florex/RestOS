// ──────────────────────────────────────────────
// Schema Prisma — RestOS Cliente (multi-tenant)
// ──────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// RESTAURANTS — Tenants del sistema
// ──────────────────────────────────────────────
model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  sections       Section[]
  tables         Table[]
  menuItems      MenuItem[]
  orders         Order[]
  sales          Sale[]
  inventoryItems InventoryItem[]
  staffMembers   StaffMember[]
  reservations   Reservation[]
  takeawayOrders TakeawayOrder[]

  @@map("restaurants")
}

// ──────────────────────────────────────────────
// AUTH
// ──────────────────────────────────────────────
model User {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  username     String
  email        String
  password     String
  name         String
  role         UserRole   @default(STAFF)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ordersCreated    Order[]         @relation("OrderCreatedBy")
  salesCreated     Sale[]          @relation("SaleRegisteredBy")
  takeawaysCreated TakeawayOrder[] @relation("TakeawayCreatedBy")

  @@unique([restaurantId, username])
  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@map("users")
}

enum UserRole {
  ADMIN
  WAITER
  STAFF
}

// ──────────────────────────────────────────────
// SECCIONES
// ──────────────────────────────────────────────
model Section {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  color        String     @default("#64748b")
  order        Int        @default(0)
  tables       Table[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("sections")
}

// ──────────────────────────────────────────────
// MESAS
// ──────────────────────────────────────────────
model Table {
  id           Int         @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  number       Int
  status       TableStatus @default(AVAILABLE)
  capacity     Int         @default(4)
  enabled      Boolean     @default(true)
  guestCount   Int?
  openedAt     DateTime?
  sectionId    Int?
  section      Section?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  orders       Order[]
  sales        Sale[]
  reservations Reservation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([sectionId])
  @@map("tables")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  BILL_REQUESTED
  RESERVED
}

// ──────────────────────────────────────────────
// MENÚ
// ──────────────────────────────────────────────
model MenuItem {
  id           Int         @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  category     String
  price        Decimal     @db.Decimal(10, 2)
  description  String?     @db.Text
  stock        StockStatus @default(IN_STOCK)
  enabled      Boolean     @default(true)
  imageUrl     String?
  orderItems   OrderItem[]
  saleItems    SaleItem[]
  takeawayItems TakeawayItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([restaurantId])
  @@map("menu_items")
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

// ──────────────────────────────────────────────
// PEDIDOS
// ──────────────────────────────────────────────
model Order {
  id           Int       @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      Int
  table        Table     @relation(fields: [tableId], references: [id], onDelete: Cascade)
  items        OrderItem[]
  notes        String?
  createdById  Int?
  createdBy    User?     @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())

  @@index([restaurantId])
  @@index([tableId])
  @@map("orders")
}

model OrderItem {
  id         Int       @id @default(autoincrement())
  orderId    Int
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId Int?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  itemName   String
  quantity   Int
  price      Decimal   @db.Decimal(10, 2)
  notes      String?

  @@index([orderId])
  @@map("order_items")
}

// ──────────────────────────────────────────────
// VENTAS
// ──────────────────────────────────────────────
model Sale {
  id             Int           @id @default(autoincrement())
  restaurantId   Int
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId        Int?
  table          Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableNumber    Int
  paymentMethod  PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  notes          String?       @db.Text
  imageUrl       String?
  registeredById Int?
  registeredBy   User?         @relation("SaleRegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)
  items          SaleItem[]
  closedAt       DateTime
  createdAt      DateTime      @default(now())

  @@index([restaurantId])
  @@index([closedAt])
  @@map("sales")
}

model SaleItem {
  id         Int       @id @default(autoincrement())
  saleId     Int
  sale       Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  menuItemId Int?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  itemName   String
  category   String
  quantity   Int
  price      Decimal   @db.Decimal(10, 2)
  subtotal   Decimal   @db.Decimal(10, 2)

  @@index([saleId])
  @@index([menuItemId])
  @@map("sale_items")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

// ──────────────────────────────────────────────
// INVENTARIO
// ──────────────────────────────────────────────
model InventoryItem {
  id           Int               @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  category     InventoryCategory @default(FOOD)
  quantity     Float
  unit         String
  minStock     Float             @default(0)
  supplier     String?
  lastRestocked DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([restaurantId])
  @@map("inventory_items")
}

enum InventoryCategory {
  FOOD
  BEVERAGE
  SUPPLIES
  EQUIPMENT
}

// ──────────────────────────────────────────────
// STAFF
// ──────────────────────────────────────────────
model StaffMember {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  email        String
  role         StaffRole  @default(WAITER)
  phone        String?
  active       Boolean    @default(true)
  cuit         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@map("staff_members")
}

enum StaffRole {
  WAITER
  CHEF
  MANAGER
  CASHIER
}

// ──────────────────────────────────────────────
// RESERVAS
// ──────────────────────────────────────────────
model Reservation {
  id           Int               @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      Int?
  table        Table?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String?
  partySize    Int
  reservedAt   DateTime
  duration     Int               @default(90)
  status       ReservationStatus @default(CONFIRMED)
  notes        String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([restaurantId])
  @@index([reservedAt])
  @@index([status])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ──────────────────────────────────────────────
// PEDIDOS PARA LLEVAR
// ──────────────────────────────────────────────
model TakeawayOrder {
  id            Int            @id @default(autoincrement())
  restaurantId  Int
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String?
  status        TakeawayStatus @default(OPEN)
  notes         String?        @db.Text
  paymentMethod PaymentMethod?
  amountPaid    Decimal?       @db.Decimal(10, 2)
  total         Decimal?       @db.Decimal(10, 2)
  createdById   Int?
  createdBy     User?          @relation("TakeawayCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  paidAt        DateTime?
  items         TakeawayItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@map("takeaway_orders")
}

model TakeawayItem {
  id         Int           @id @default(autoincrement())
  orderId    Int
  order      TakeawayOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId Int?
  menuItem   MenuItem?     @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  itemName   String
  quantity   Int
  price      Decimal       @db.Decimal(10, 2)
  notes      String?

  @@index([orderId])
  @@map("takeaway_items")
}

enum TakeawayStatus {
  OPEN
  READY
  PAID
  CANCELLED
}
